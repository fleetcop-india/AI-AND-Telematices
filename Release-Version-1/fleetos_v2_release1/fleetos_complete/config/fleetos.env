# ╔══════════════════════════════════════════════════════════════╗
# ║   Fleet OS — Central Configuration                          ║
# ║   Change IPs here to migrate from localhost to cloud        ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Infrastructure ─────────────────────────────────────────────
FLEETOS_KAFKA_BROKERS=127.0.0.1:9092
FLEETOS_DB_URL=postgresql://fleetos:fleetos123@127.0.0.1:5432/fleetos
FLEETOS_DB_HOST=127.0.0.1
FLEETOS_DB_PORT=5432
FLEETOS_DB_NAME=fleetos
FLEETOS_DB_USER=fleetos
FLEETOS_DB_PASS=fleetos123

# ── Agent Service IPs ───────────────────────────────────────────
# Change 127.0.0.1 → actual server IP to deploy on cloud
FLEETOS_GPS_IP=127.0.0.1
FLEETOS_GPS_PORT=8080
FLEETOS_GPS_MGMT_PORT=9080

FLEETOS_VIDEO_IP=127.0.0.1
FLEETOS_VIDEO_PORT=8088
FLEETOS_VIDEO_RTSP_PORT=8554
FLEETOS_VIDEO_WEBRTC_PORT=8089
FLEETOS_VIDEO_MGMT_PORT=9088

FLEETOS_ROUTE_IP=127.0.0.1
FLEETOS_ROUTE_PORT=8082
FLEETOS_ROUTE_MGMT_PORT=9082

FLEETOS_DRIVER_IP=127.0.0.1
FLEETOS_DRIVER_PORT=8084
FLEETOS_DRIVER_MGMT_PORT=9084

FLEETOS_MAINT_IP=127.0.0.1
FLEETOS_MAINT_PORT=8090
FLEETOS_MAINT_MGMT_PORT=9090

FLEETOS_INDUSTRY_IP=127.0.0.1
FLEETOS_INDUSTRY_PORT=8087
FLEETOS_INDUSTRY_MGMT_PORT=9087

FLEETOS_NOTIF_IP=127.0.0.1
FLEETOS_NOTIF_PORT=8083
FLEETOS_NOTIF_MGMT_PORT=9083

FLEETOS_REPORT_IP=127.0.0.1
FLEETOS_REPORT_PORT=8086
FLEETOS_REPORT_MGMT_PORT=9086

FLEETOS_WEBPANEL_IP=127.0.0.1
FLEETOS_WEBPANEL_PORT=4001

FLEETOS_DEVOPS_IP=127.0.0.1
FLEETOS_DEVOPS_PORT=8099

# ── JWT / Auth ──────────────────────────────────────────────────
FLEETOS_JWT_SECRET=fleetos-dev-secret-change-in-prod
FLEETOS_JWT_EXPIRES=86400

# ── Feature Flags ───────────────────────────────────────────────
FLEETOS_VIDEO_ENABLED=true
FLEETOS_CONSTRUCTION_ENABLED=true
FLEETOS_AGRICULTURE_ENABLED=true
FLEETOS_LOG_LEVEL=DEBUG

# ── Geocoder (Address Resolution) ──────────────────────────────
# Provider: nominatim (free), arcgis (free), google, opencage, mapbox
GEOCODER_PROVIDER=nominatim
GEOCODER_ENABLED=true
# Set your API key if using google/opencage/mapbox:
GEOCODER_API_KEY=

# ── Kafka Mode (set automatically by install.sh) ─────────────────
# podman = run as Podman container (default on Fedora)
# docker  = run as Docker container
# binary  = run as downloaded binary (Ubuntu/Debian default)
KAFKA_MODE=binary

# ── Aliases for start-all.sh ───────────────────────────────────────────────
KAFKA_MODE=auto
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=fleetos
DB_USER=fleetos
DB_PASS=fleetos123
WEB_PORT=4001
LOG_LEVEL=info
